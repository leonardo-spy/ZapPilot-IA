GROQ_API_KEY=gsk_your_key_here
LOCAL_LLM_URL=http://127.0.0.1:8081/v1
LOCAL_LLM_MODEL=prism-ml/Bonsai-8B-gguf:Q1_0
GROQ_MODEL=llama-3.1-8b-instant

# Embeddings: Google como primário, local como fallback
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_EMBEDDING_MODEL=gemini-embedding-2
GOOGLE_EMBEDDING_DIM=768
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Rate limit (Google Embedding API)
GOOGLE_EMBEDDING_WAIT_ON_LIMIT=true
GOOGLE_EMBEDDING_MAX_RETRIES=3
GOOGLE_EMBEDDING_SERVER_MAX_RETRIES=10
GOOGLE_EMBEDDING_RPM=100

# Domínio do bot (android_box | tirzepatida | custom)
BOT_DOMAIN=android_box
COLLECTION_NAME=android_box_suporte

DATA_DIR=./data
WHATSAPP_JSON=./input/whatsapp_chats.json
WHATSAPP_DB=./input/msgstore.db
# Fonte de dados: auto | json | db
# auto = prioriza .db se existir, senão usa .json
WHATSAPP_SOURCE=auto
